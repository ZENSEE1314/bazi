# Copy to .env for local dev. Railway injects these via the service UI.

# PostgreSQL — on Railway, reference ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://bazi:bazi@localhost:5432/bazi

# JWT — generate a long random string for prod
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=1440

# Freemium
FREE_PROFILE_LIMIT=3

# CORS — comma separated. Use "*" for open dev, or your Railway domain in prod.
CORS_ORIGINS=*

# Where the built frontend lives inside the container.
STATIC_DIR=frontend/dist
